# Local dev (Vite proxy to backend)
# VITE_API_URL=/api

# Production — Render backend base URL (include /api if routes use /api/* elsewhere)
# Option A (recommended): base ends with /api → login calls /api/auth/login
VITE_API_URL=https://venuecrm-backend1.onrender.com/

# Option B: base without /api → login calls /auth/login (also supported)
# VITE_API_URL=https://your-app-name.onrender.com

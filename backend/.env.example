# Required — include database name: /venue_crm
MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.xxxxx.mongodb.net/venue_crm?retryWrites=true&w=majority

# Optional — use if querySrv ECONNREFUSED (copy "Standard connection" from Atlas Connect)
# MONGO_URI_STANDARD=mongodb://USERNAME:PASSWORD@cluster0-shard-00-00.xxxxx.mongodb.net:27017,.../venue_crm?ssl=true&authSource=admin

PORT=5000
NODE_ENV=development
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRE=7d
